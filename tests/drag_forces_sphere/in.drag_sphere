# Sphere drag validation -- 162 markers, 96^3 grid
# M=50 for stiff penalty coupling
# Hasimoto: U = F/(6*pi*mu*R) * (1 - 2.837*R/L + ...)
# Data: python gen_sphere_data.py 4 3.0 24.0 1.0

units           lj
dimension       3
boundary        p p p
atom_style      atomic
atom_modify     map array

read_data       sphere_markers.data
mass            1 0.30864198          # M_total = 50 / 162 markers

pair_style      none
group           sphere type 1

timestep        0.25

variable        Nc equal 96
variable        dxp equal 0.5
variable        L equal ${Nc}*${dxp}
variable        R equal 3.0
variable        Nmarkers equal 162
variable        nu_phys equal 0.1
variable        rho0 equal 1.0

variable        F_total equal 0.005
variable        F_atom equal ${F_total}/${Nmarkers}
fix             push sphere addforce ${F_atom} 0.0 0.0

fix             body sphere rigid/nve single

# Compensating body force for zero net momentum
variable        g_comp equal -${F_total}/(${rho0}*v_L*v_L*v_L)

fix             flow sphere couplb ${Nc} ${Nc} ${Nc} ${nu_phys} ${rho0} &
                dx ${dxp} &
                kernel roma &
                gravity v_g_comp 0.0 0.0 &
                check_every 2000

variable        vx equal vx[1]
variable        vy equal vy[1]
variable        vz equal vz[1]

variable        mu equal ${rho0}*${nu_phys}
variable        aoverL equal ${R}/${L}
variable        K equal 1.0-2.837*v_aoverL+4.19*v_aoverL^3
variable        U_stokes equal ${F_total}/(6.0*PI*${mu}*${R})
variable        U_corrected equal v_U_stokes*v_K

thermo          1000
thermo_style    custom step v_vx v_vy v_vz cpu

run             30000

print "============================================================"
print "  SPHERE DRAG VALIDATION"
print "============================================================"
print "  R=${R}  ${Nmarkers} markers  ${Nc}^3 cells  dx=${dxp}  L/D=$(v_L/(2*v_R))"
print "  M=50 (penalty/drag ratio = $(50*4.0/5.655))"
print "  Hasimoto K = ${K} (R/L = ${aoverL})"
print "  U_Stokes    = ${U_stokes}"
print "  U_corrected = ${U_corrected}"
print "  U_measured  = ${vx}"
print "  Error       = $((v_vx-v_U_corrected)/v_U_corrected*100) %"
print "  v_y=${vy}  v_z=${vz}"
print "============================================================"